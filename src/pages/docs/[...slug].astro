---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/nav.astro";
import Footer from "@/components/footer.astro";
import Giscus from "@/components/Giscus.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const docs = await getCollection("docs");
  return docs.map((doc) => ({
    params: { slug: doc.id },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);

const allDocs = await getCollection("docs");

function getAdjacentDocs(currentId: string) {
  const sorted = allDocs.sort((a, b) => (a.data.date?.valueOf() ?? 0) - (b.data.date?.valueOf() ?? 0));
  const idx = sorted.findIndex((d) => d.id === currentId);
  return {
    prev: idx > 0 ? sorted[idx - 1] : null,
    next: idx < sorted.length - 1 ? sorted[idx + 1] : null,
  };
}

const { prev, next } = getAdjacentDocs(doc.id);
---

<Layout title={doc.data.title}>
  <Nav />
  <main class="max-w-3xl mx-auto py-24">
    <a href="/docs" class="text-[var(--sec)] hover:underline mb-6 inline-block">&larr; 返回文档</a>
    <article>
      <h1 class="text-4xl md:text-5xl font-medium text-[var(--white)] mb-4">{doc.data.title}</h1>
      {doc.data.description && (
        <p class="text-[var(--white-icon)] mb-8">{doc.data.description}</p>
      )}
      <div class="prose prose-invert max-w-none text-[var(--white)]">
        <Content />
      </div>
      <Giscus />
    </article>

    <div class="flex justify-between mt-12 pt-8 border-t border-[#ffffff10]">
      {prev ? (
        <a href={`/docs/${prev.id}`} class="text-[var(--sec)] hover:underline">&larr; {prev.data.title}</a>
      ) : <span />}
      {next ? (
        <a href={`/docs/${next.id}`} class="text-[var(--sec)] hover:underline">{next.data.title} &rarr;</a>
      ) : <span />}
    </div>
  </main>
  <Footer />
</Layout>

<style is:global>
  .prose h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: var(--white);
  }
  .prose h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--white);
  }
  .prose h4 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
    color: var(--white);
  }
  .prose p {
    margin-bottom: 1rem;
    line-height: 1.75;
    color: var(--white-icon);
  }
  .prose ul, .prose ol {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .prose li {
    margin-bottom: 0.5rem;
    color: var(--white-icon);
  }
  .prose code {
    background: #1a1a2e;
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    color: var(--sec);
  }
  .prose pre {
    background: #1a1a2e;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }
  .prose pre code {
    background: none;
    padding: 0;
    color: var(--white);
  }
  .prose a {
    color: var(--sec);
    text-decoration: underline;
  }
  .prose strong {
    color: var(--white);
    font-weight: 600;
  }
  .prose hr {
    border-color: #ffffff10;
    margin: 2rem 0;
  }
  .prose blockquote {
    border-left: 3px solid var(--sec);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--white-icon);
  }
</style>
