---

<section id="projects" class="py-12 border-t border-[#ffffff10] text-[var(--white)]">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">CTF 靶场</h2>
    <h3 class="text-4xl md:text-5xl font-medium mb-8">练习方向</h3>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        projects.map((project) => (
          <a
            href={project.link}
            class="group block p-6 rounded-2xl border border-[var(--white-icon-tr)] bg-[#1414149c] hover:bg-[var(--white-icon-tr)] hover:border-[var(--sec)] transition-all duration-300"
          >
            <div class="text-[var(--sec)] mb-4" set:html={project.icon} />
            <h4 class="text-xl font-semibold mb-2">{project.title}</h4>
            <p class="text-sm text-[var(--white-icon)] mb-3">{project.description}</p>
            <span class="text-xs text-[var(--sec)] border border-[var(--sec)] rounded-full px-3 py-1">
              {project.status}
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
